{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "http://34.59.79.51:8080/api/$1" },
    { "source": "/ws/(.*)", "destination": "http://34.59.79.51:8080/ws/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
