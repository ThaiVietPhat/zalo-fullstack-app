{
  "rewrites": [
    { "source": "/api/:path*", "destination": "http://34.59.79.51:8080/api/:path*" },
    { "source": "/ws/:path*", "destination": "http://34.59.79.51:8080/ws/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
