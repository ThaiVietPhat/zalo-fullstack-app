# ============================================================
# RAILWAY ENVIRONMENT VARIABLES — copy vào Railway Dashboard
# Settings → Variables → Raw Editor
# ============================================================

# ========================
# DATABASE (Railway MySQL addon)
# Dùng reference syntax của Railway — tự động lấy từ MySQL service
# ========================
DB_HOST=${{MySQL.MYSQLHOST}}
DB_NAME=${{MySQL.MYSQLDATABASE}}
DB_USERNAME=${{MySQL.MYSQLUSER}}
DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}
DB_PORT=${{MySQL.MYSQLPORT}}

# ========================
# CLOUDFLARE R2 (thay S3)
# Lấy từ: Cloudflare Dashboard → R2 → Manage R2 API Tokens
# ========================
AWS_ACCESS_KEY_ID=<R2_Access_Key_ID>
AWS_SECRET_ACCESS_KEY=<R2_Secret_Access_Key>
AWS_S3_BUCKET=<tên_bucket_R2>
AWS_REGION=auto
AWS_S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# ========================
# JWT
# Tạo secret ngẫu nhiên: openssl rand -hex 32
# ========================
JWT_SECRET=<secret_tối_thiểu_32_ký_tự>

# ========================
# AI (Groq — miễn phí tại console.groq.com)
# ========================
GROQ_API_KEY=<groq_api_key>

# ========================
# EMAIL (Brevo)
# ========================
BREVO_API_KEY=<brevo_api_key>
BREVO_SENDER_EMAIL=<email_gửi>
BREVO_SENDER_NAME=Zalo Clone

# ========================
# CORS
# Điền sau khi có Railway URL — thêm vào cuối danh sách
# ========================
CORS_ALLOWED_ORIGINS=https://zalo-fullstack-app.vercel.app,https://<your-app>.up.railway.app

# ========================
# PERFORMANCE (giữ nguyên, không cần đổi)
# ========================
HIKARI_MAX_POOL=5
HIKARI_MIN_IDLE=2
SHOW_SQL=false
LOG_LEVEL_BIND=warn
LOG_LEVEL_WEB=INFO
